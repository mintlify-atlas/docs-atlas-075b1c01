  "keyFeatures": [
    "11 real-time DSP modes (0–10) driven by ML model output over UDP at 10 Hz",
    "Protocol v2 contract with pinned fingerprint and strict packet decoding",
    "Manifest-backed routing for instruments, banks, chords, motifs, and spatial patterns",
    "JSONL training substrate logging (frames, events, session metadata) at 10 Hz",
    "Session replay with optional audio injection and speed control",
    "Audio safety rails: reverb wet ≤ 0.50, master limiter at −1 dBFS, per-mode voice caps",
    "4-panel SwiftUI control room UI with live human labels (good/too_much/too_flat)",
    "Visual stage rendered at 24 Hz using SwiftUI Canvas with Metal shaders",
    "Headless replay via CLI args and UI replay by session ID",
    "Input audio recording to CAF/WAV for training data collection"
  ],
  "publicApiSurface": [
    "TubMLClient.startLoop(recordInputAudio:replayMode:replayedSessionId:runMode:)",
    "TubMLClient.stopLoop()",
    "TubMLClient.setMode(_:)",
    "TubMLClient.pulseJolt()",
    "TubMLClient.pulseClear()",
    "TubMLClient.setJoltHeld(_:)",
    "TubMLClient.setHumanLabel(_:)",
    "TubMLClient.reconfigureEndpoint(host:port:)",
    "TubMLClient.replayTrace(inputPath:fasterThanRealtime:speedMultiplier:bundleIdOverride:completion:)",
    "ModeContract.enforceIncoming(modelOut:currentMode:)",
    "ModeContract.safeDefaults(mode:tsMs:contractViolation:)",
    "ModeContract.contractLockStatus()",
    "ModeContract.clamp(params:mode:)",
    "ModeContract.validate(picks:mode:)",
    "ModeContract.sanitize(visual:mode:)",
    "ModelIn (protocol v2 packet)",
    "ModelOut (protocol v2 packet)",
    "Features (audio feature vector)",
    "Picks (manifest-backed routing picks)",
    "VisualOut (visual head for stage rendering)",
    "ManifestCatalog.shared.resolve(mode:picks:)"
  ]
